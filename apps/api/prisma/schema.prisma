generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DependencyType {
  FS
}

model Project {
  id           String       @id @default(uuid()) @db.Uuid
  name         String
  startDate    DateTime
  tasks        Task[]
  dependencies Dependency[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Task {
  id                   String       @id @default(uuid()) @db.Uuid
  projectId            String       @db.Uuid
  project              Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name                 String
  startDate            DateTime
  durationDays         Int
  progress             Int          @default(0)
  endDate              DateTime?
  outgoingDependencies Dependency[] @relation("DependencyFromTask")
  incomingDependencies Dependency[] @relation("DependencyToTask")
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([projectId])
}

model Dependency {
  id         String         @id @default(uuid()) @db.Uuid
  projectId  String         @db.Uuid
  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromTaskId String         @db.Uuid
  fromTask   Task           @relation("DependencyFromTask", fields: [fromTaskId], references: [id], onDelete: Cascade)
  toTaskId   String         @db.Uuid
  toTask     Task           @relation("DependencyToTask", fields: [toTaskId], references: [id], onDelete: Cascade)
  type       DependencyType @default(FS)
  lagDays    Int            @default(0)
  createdAt  DateTime       @default(now())

  @@index([projectId])
  @@unique([projectId, fromTaskId, toTaskId])
}
